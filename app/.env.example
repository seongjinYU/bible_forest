# ─────────────────────────────────────────────────────────────
# Bible Forest — 환경변수 템플릿
# 이 파일을 `.env.local` 로 복사한 뒤 실제 값을 채워 넣으세요.
#   cp .env.example .env.local
# ─────────────────────────────────────────────────────────────

# Supabase 프로젝트 URL / 공개 anon 키
# (Supabase 대시보드 → Project Settings → API)
# NEXT_PUBLIC_ 접두사는 브라우저에 노출됩니다.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# 서버 전용 service_role 키 (RLS 우회 권한).
# ⚠️ 절대 클라이언트 코드/깃에 노출 금지. 서버 라우트에서만 사용.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# 어드민 로그인 비밀번호 (POST /api/v1/admin/login 에서 검증)
ADMIN_PASSWORD=set-a-strong-password
